    "# ============================================================\n",
    "# ORIGINAL FLAWED CODE — Study the problems ,
    "# ============================================================\n",
    "\"\"\"\n",
    "import pandas as pd\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.metrics import accuracy_score\n",
    "\n",
    "df = pd.read_csv(\"data.csv\")\n",
    "\n",
    "# BUG 1: TotalCharges not converted to numeric\n",
    "# BUG 2: Scaler fit on ENTIRE dataset before split (data leakage!)\n",
    "scaler = StandardScaler()\n",
    "df_scaled = scaler.fit_transform(df)\n",
    "\n",
    "# BUG 3: Target variable \"Churn\" included in X (data leakage!)\n",
    "X = df                           # includes Churn column!\n",
    "y = df[\"Churn\"]\n",
    "\n",
    "# BUG 4: No train/test split at all\n",
    "model = RandomForestClassifier()\n",
    "model.fit(X, y)\n",
    "\n",
    "# BUG 5: Evaluating on TRAINING data (always ~100%)\n",
    "print(accuracy_score(y, model.predict(X)))\n",
    "\n",
    "# BUG 6: Categorical columns not encoded → model receives strings\n",
    "# BUG 7: Class imbalance ignored (26% churn = misleading accuracy)\n",
    "# BUG 8: No hyperparameter tuning, no random_state (non-reproducible)\n",
    "# BUG 9: No model saved (can't deploy!)\n",
    "# BUG 10: Using accuracy as sole metric on imbalanced data\n",
    "\"\"\"\n",
    "\n"
   ]
  },
  {
